{
    "name": "@hlw-uni/mp-vite-plugin",
    "version": "1.0.26",
    "description": "UniApp Vite 编译插件 — 环境变量注入、SCSS 主题、Auto-Import、全局 API 注入",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "publish:npm": "pnpm build && npm publish --access public"
    },
    "peerDependencies": {
        "@dcloudio/vite-plugin-uni": ">=3.0.0",
        "@hlw-uni/mp-core": ">=1.0.10",
        "vite": ">=5.0.0"
    },
    "dependencies": {
        "@antfu/utils": "^0.7.7",
        "unplugin-auto-import": "^0.17.5"
    },
    "devDependencies": {
        "@dcloudio/types": "^3.4.8",
        "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
        "@hlw-uni/mp-core": "1.0.10",
        "@types/node": "^20.11.0",
        "typescript": "^4.9.4",
        "vite": "5.2.8",
        "vite-plugin-dts": "^4.5.4",
        "@vitejs/plugin-vue": "^5.1.0"
    }
}
